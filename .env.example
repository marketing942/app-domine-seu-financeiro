# Segredo para assinar os tokens JWT (obrigatório em produção)
# Gere um valor seguro com: openssl rand -base64 32
JWT_SECRET=mude-este-valor-em-producao

# Diretório onde o banco SQLite será salvo (opcional, padrão: ./data)
# No Vercel, use /tmp para escrita temporária ou configure um banco externo
DB_DIR=/tmp
